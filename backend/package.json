{
  "name": "backend",
  "scripts": {
    "dev": "ts-node-dev --poll --respawn --transpile-only src/index.ts",
    "db:init": "tsx src/database/init.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx src/database/migrate.ts",
    "db:seed": "tsx ./src/database/seed.ts",
    "prod:db:init": "node dist/database/init.js",
    "prod:db:migrate": "node dist/database/migrate.js",
    "prod:db:seed": "node dist/database/seed.js",
    "build": "tsc",
    "start": "node dist/index.js",
    "key:generate": "node -e \"console.log(require('crypto').randomBytes(32).toString('base64'))\"",
    "test": "vitest run"
  },
  "packageManager": "yarn@4.9.2",
  "dependencies": {
    "@types/socket.io": "^3.0.2",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.4.19",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.0",
    "mysql2": "^3.18.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.2",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.9",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
